{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flutter Web (localhost:8080)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "8080", "--web-hostname", "localhost"],
      "port": 8080
    },
    {
      "name": "Flutter Web (Chrome)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "chrome", "--web-port", "5000"],
      "port": 5000
    }
  ]
}
