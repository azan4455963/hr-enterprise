rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return userDoc().role;
    }

    function permissions() {
      return userDoc().permissions;
    }

    function hasPerm(perm) {
      return userExists() && (
        permissions().hasAny(['*']) ||
        permissions().hasAny([perm])
      );
    }

    function isAdminRole() {
      return userExists() && role() == 'super_admin';
    }

    function isManager() {
      return userExists() && role() == 'manager';
    }

    function sameDepartment(departmentId) {
      return userDoc().departmentId == departmentId;
    }

    match /users/{userId} {
      // Any signed-in user can read the basic directory (needed so the chat
      // recipient picker can find their admin / director). Writes stay locked.
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId || isAdminRole()
      );
      allow delete: if isAdminRole();
    }

    // A director (manager) is limited to their managed department(s); admin
    // sees all; non-managers aren't department-restricted here.
    function inMyDept(dept) {
      return isAdminRole() ||
        role() != 'manager' ||
        (('managedDepartments' in userDoc()) &&
            userDoc().managedDepartments.hasAny([dept])) ||
        dept == userDoc().departmentName;
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn() && hasPerm('employees_view') &&
        inMyDept(resource.data.departmentName);
      allow create: if isSignedIn() && hasPerm('employees_create') &&
        inMyDept(request.resource.data.departmentName);
      allow update: if isSignedIn() &&
        (hasPerm('employees_edit') || hasPerm('employees_delete')) &&
        inMyDept(resource.data.departmentName) &&
        inMyDept(request.resource.data.departmentName);
      allow delete: if isSignedIn() && hasPerm('employees_delete') &&
        inMyDept(resource.data.departmentName);

      // Free-form per-employee records (assets, documents, notes, …).
      // Admins/directors with employees_view can read; the linked employee can
      // read only records explicitly marked visible. Writes need employees_edit.
      match /records/{recordId} {
        allow read: if isSignedIn() && (
          hasPerm('employees_view') ||
          (hasLinkedEmployee() &&
            userDoc().employeeId == employeeId &&
            resource.data.visibleToEmployee == true)
        );
        allow create, update, delete: if isSignedIn() && hasPerm('employees_edit');
      }

      // Uploaded files (CNIC, contracts, certificates). Admins/directors read;
      // writes need employees_edit.
      match /documents/{docId} {
        allow read: if isSignedIn() && hasPerm('employees_view');
        allow create, update, delete: if isSignedIn() && hasPerm('employees_edit');
      }
    }

    function hasLinkedEmployee() {
      return userDoc().employeeId != null && userDoc().employeeId != '';
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && hasPerm('attendance_view');
      // Self check-in / QR writes own record; a manager/admin with
      // attendance_edit may mark their team (record carries departmentName,
      // scoped via inMyDept — admins pass for any department).
      allow create: if isSignedIn() && (
        (hasPerm('attendance_view') && hasLinkedEmployee() &&
          request.resource.data.employeeId == userDoc().employeeId) ||
        (hasPerm('attendance_edit') &&
          ('departmentName' in request.resource.data) &&
          inMyDept(request.resource.data.departmentName))
      );
      allow update: if isSignedIn() && (
        (hasPerm('attendance_view') && hasLinkedEmployee() &&
          resource.data.employeeId == userDoc().employeeId) ||
        (hasPerm('attendance_edit') &&
          ('departmentName' in request.resource.data) &&
          inMyDept(request.resource.data.departmentName))
      );
      allow delete: if isSignedIn() && hasPerm('attendance_edit');
    }

    match /attendance_qr_sessions/{id} {
      allow read: if isSignedIn() && hasPerm('attendance_view');
      allow write: if isSignedIn() && hasPerm('attendance_edit');
    }

    match /leave_requests/{id} {
      allow read: if isSignedIn() && hasPerm('leave_view');
      allow create: if isSignedIn() && hasPerm('leave_create');
      allow update: if isSignedIn() && (
        hasPerm('leave_approve') ||
        (hasPerm('leave_create') && resource.data.employeeId == userDoc().employeeId)
      );
      allow delete: if hasPerm('leave_approve');
    }

    match /payroll/{id} {
      // Admins/HR with payroll_view see all; a linked employee may read only
      // their own payroll (for self-service payslips / reports).
      allow read: if isSignedIn() && (
        hasPerm('payroll_view') ||
        (hasLinkedEmployee() &&
          resource.data.employeeId == userDoc().employeeId)
      );
      allow write: if isSignedIn() && hasPerm('payroll_edit');
    }

    match /onboarding_links/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasPerm('onboarding_create');
    }

    match /onboarding_submissions/{id} {
      allow read: if isSignedIn() && hasPerm('onboarding_view');
      allow create, update: if true;
      allow delete: if isSignedIn() && hasPerm('onboarding_create');
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && hasPerm('notifications_view');
      allow create: if isSignedIn();
      allow update: if isSignedIn() && hasPerm('notifications_view');
    }

    match /audit_logs/{id} {
      allow read: if isSignedIn() && hasPerm('audit_view');
      allow create: if isSignedIn();
    }

    match /company_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasPerm('settings_edit');
    }

    match /fcm_tokens/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /departments/{id} {
      allow read: if isSignedIn();
      allow write: if isAdminRole();
    }

    match /google_sheets/{id} {
      allow read: if isSignedIn() && hasPerm('googleSheets_view');
      allow write: if isSignedIn() && (
        hasPerm('googleSheets_create') ||
        hasPerm('googleSheets_edit') ||
        hasPerm('googleSheets_delete')
      );
    }

    match /drive_links/{id} {
      allow read: if isSignedIn() && hasPerm('googleSheets_view');
      allow write: if isSignedIn() && (
        hasPerm('googleSheets_create') ||
        hasPerm('googleSheets_edit') ||
        hasPerm('googleSheets_delete')
      );
    }

    // A director only touches tables tagged to a department they manage; an
    // admin (or any non-manager grantee) sees all.
    function tableInScope(data) {
      return isAdminRole() ||
        role() != 'manager' ||
        (('departmentName' in data) &&
          userDoc().managedDepartments.hasAny([data.departmentName]));
    }

    match /data_tables/{id} {
      allow read: if isSignedIn() && hasPerm('tables_manage') &&
        tableInScope(resource.data);
      allow create: if isSignedIn() && hasPerm('tables_manage') &&
        tableInScope(request.resource.data);
      allow update: if isSignedIn() && hasPerm('tables_manage') &&
        tableInScope(resource.data) && tableInScope(request.resource.data);
      allow delete: if isSignedIn() && hasPerm('tables_manage') &&
        tableInScope(resource.data);
    }

    match /assets/{id} {
      allow read: if isSignedIn() && hasPerm('assets_manage');
      allow write: if isSignedIn() && hasPerm('assets_manage');
    }

    // Feature-access requests: a user creates their own (pending); only an
    // admin can decide them. Users read their own; admins read all.
    match /access_requests/{id} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdminRole());
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update, delete: if isAdminRole();
    }

    // 1-to-1 chat. Participants read/write their own conversation; an admin can
    // read every conversation (read-only monitor) but can only post in ones they
    // are actually a participant of.
    match /conversations/{cid} {
      allow read: if isSignedIn() &&
        (request.auth.uid in resource.data.participantIds || isAdminRole());
      allow create: if isSignedIn() &&
        (request.auth.uid in request.resource.data.participantIds);
      allow update: if isSignedIn() &&
        (request.auth.uid in resource.data.participantIds);

      match /messages/{mid} {
        allow read: if isSignedIn() && (
          (request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(cid)).data.participantIds) ||
          isAdminRole()
        );
        allow create: if isSignedIn() &&
          request.resource.data.senderId == request.auth.uid &&
          (request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(cid)).data.participantIds);
      }
    }
  }
}
