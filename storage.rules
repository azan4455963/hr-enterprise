rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /employees/{employeeId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /onboarding/{submissionId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if true;
    }
  }
}
